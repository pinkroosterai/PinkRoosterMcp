# ─── Required ────────────────────────────────────────────────────────────────
# PostgreSQL password. Used by the database and connection strings.
POSTGRES_PASSWORD=pinkrooster

# ─── Optional ────────────────────────────────────────────────────────────────
# API authentication key. Leave empty for open access (no auth).
# When set, all API and MCP requests require this key via X-Api-Key header.
API_KEY=

# MCP server authentication key (optional, separate from API_KEY).
# Leave empty for open access. When set, MCP clients must pass this key.
MCP_API_KEY=

